# ==============================================================================
# TURAS Docker Environment Configuration
# ==============================================================================
# Copy this file to .env and set TURAS_PROJECTS_ROOT to the folder on your
# machine that contains your Turas project files (configs, data, outputs).
#
# This folder must be the same Google Drive folder synced on both machines.
# It will be mounted as /data inside the Docker container.
#
# IMPORTANT: Do NOT commit .env to Git. It contains machine-specific paths.
# ==============================================================================

# The full path to your local TurasProjects folder on this machine.
#
# Windows example (Google Drive):
#   TURAS_PROJECTS_ROOT=G:/My Drive/TurasProjects
#
# Mac example (Google Drive):
#   TURAS_PROJECTS_ROOT=/Users/jess/Library/CloudStorage/GoogleDrive-you@gmail.com/My Drive/TurasProjects
#
# If you leave this unset, Docker will use the ./data folder next to
# docker-compose.yml as a local fallback.

TURAS_PROJECTS_ROOT=G:/My Drive/TurasProjects
