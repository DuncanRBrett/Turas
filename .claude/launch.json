{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "conjoint-report",
      "runtimeExecutable": "/usr/local/bin/npx",
      "runtimeArgs": ["serve", "examples/conjoint/v3_demo/output", "-l", "8765", "--no-clipboard"],
      "port": 8765
    },
    {
      "name": "hub-report",
      "runtimeExecutable": "/bin/bash",
      "runtimeArgs": ["-c", "export PATH=/usr/local/bin:$PATH && npx serve examples/report_hub -l 8770 --no-clipboard"],
      "port": 8770
    }
  ]
}
