{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "hub-app-static",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["-e", "const http=require('http'),fs=require('fs'),path=require('path'),dir=path.join(process.cwd(),'modules/hub_app/app'),types={'.html':'text/html','.css':'text/css','.js':'application/javascript'};http.createServer((q,r)=>{let f=path.join(dir,q.url==='/'?'index.html':q.url);fs.readFile(f,(e,d)=>{if(e){r.writeHead(404);r.end('Not found');return}r.writeHead(200,{'Content-Type':types[path.extname(f)]||'text/plain'});r.end(d)})}).listen(8765,()=>console.log('Serving on 8765'))"],
      "port": 8765
    },
    {
      "name": "showreel",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["-e", "const http=require('http'),fs=require('fs'),path=require('path'),dir='/Users/duncan/Library/CloudStorage/OneDrive-Personal/DB Files/Projects/Turas Showreel',types={'.html':'text/html','.css':'text/css','.js':'application/javascript','.xlsx':'application/octet-stream'};http.createServer((q,r)=>{let u=decodeURIComponent(q.url==='/'?'/index.html':q.url),f=path.join(dir,u);if(q.url==='/'){let files=fs.readdirSync(dir).filter(x=>x.endsWith('.html')).map(x=>'<li><a href=\"/'+encodeURIComponent(x)+'\">'+x+'</a></li>').join('');r.writeHead(200,{'Content-Type':'text/html'});r.end('<html><body><h1>Showreel</h1><ul>'+files+'</ul></body></html>');return}fs.readFile(f,(e,d)=>{if(e){r.writeHead(404);r.end('Not found');return}r.writeHead(200,{'Content-Type':types[path.extname(f)]||'text/plain'});r.end(d)})}).listen(8766,()=>console.log('Serving showreel on 8766'))"],
      "port": 8766
    }
  ]
}
